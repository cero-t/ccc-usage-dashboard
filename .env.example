# Development-only environment overrides for ccc-usage-dashboard.
# Quarkus automatically reads .env from the current working directory. Copy this
# file to .env for local development only. Installed application configuration
# belongs in ~/.ccc-usage-dashboard/config/application.properties; see README.md.

# Tool-specific ingestion flags. Set to false on machines that only use one tool.
#CCC_USAGE_DASHBOARD_CODEX_ENABLED=true
#CCC_USAGE_DASHBOARD_CLAUDE_ENABLED=true

# Ports / bind addresses
#QUARKUS_GRPC_SERVER_PORT=4317
#QUARKUS_HTTP_PORT=4318
#QUARKUS_HTTP_HOST=127.0.0.1
#QUARKUS_GRPC_SERVER_HOST=127.0.0.1

# Local development database. An explicit URL disables automatic migration.
#QUARKUS_DATASOURCE_JDBC_URL=jdbc:sqlite:/absolute/path/custom.sqlite?journal_mode=WAL&busy_timeout=10000

# Local telemetry retention
#CCC_USAGE_DASHBOARD_RETENTION_EVERY=1h
#CCC_USAGE_DASHBOARD_RETENTION_OTEL_LOG_RECORDS=14d
#CCC_USAGE_DASHBOARD_RETENTION_ANNOTATED_EVENTS=365d
#CCC_USAGE_DASHBOARD_RETENTION_USAGE_SAMPLES=365d

# Codex local data directory. The dashboard reads both known SQLite layouts
# under this directory.
#CODEX_DB_DIR=/Users/you/.codex
#CODEX_BIN=codex

# Receive-time filter for noisy OTLP log records. Set to an empty value to store
# every received OTLP log record.
#CCC_USAGE_DASHBOARD_INGEST_DROP_EVENT_KINDS=^response[.].+[.]delta$

# Advanced polling / batch tuning
#CCC_USAGE_DASHBOARD_ANNOTATE_EVERY=60s
#CCC_USAGE_DASHBOARD_ANNOTATE_BATCH_SIZE=500
#CCC_USAGE_DASHBOARD_USAGE_EVERY=60s

# CODEX_USAGE_DASHBOARD_* aliases remain supported during the v0.3 transition.
